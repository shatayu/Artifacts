# Where the artifacts API lives (local for dev, render URL for prod)
API_BASE_URL=http://localhost:3000

# Same API_KEY as the server's .env
API_KEY=CHANGEME

# Polling interval in watch mode (launchd ignores this; uses StartInterval=60s)
POLL_INTERVAL_MS=60000

# Optional: override Claude's workspace dir (the one containing artifacts.json).
# Defaults to the workspace we already discovered.
# CLAUDE_WORKSPACE_DIR=/Users/shatayu/Library/Application Support/Claude/local-agent-mode-sessions/3cac6382-4eed-4c3c-adda-a3b49db1c031/351936ed-a38a-42fd-a05b-ac73f950c80e
