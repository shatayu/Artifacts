# Server config
PORT=3000
NODE_ENV=development

# Postgres for the artifacts metadata + HTML (this app's own DB)
ARTIFACTS_DB_URL=postgres://localhost:5432/artifacts

# Postgres for live SQL queries from artifacts (your hamster-db, read-only role)
HAMSTER_DB_URL=postgres://artifacts_reader:CHANGEME@dpg-...oregon-postgres.render.com/hamsterdb

# Bearer token used by both the iOS app and the sync daemon
# Generate with: openssl rand -hex 32
API_KEY=CHANGEME

# Max time a hamster-db query can run (ms)
SQL_TIMEOUT_MS=5000
